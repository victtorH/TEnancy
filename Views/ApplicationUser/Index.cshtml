@{
    ViewData["Title"] = "Cadastro de Usuário";
}

 <link rel="stylesheet" href="~/css/CadastroELogin.css" asp-append-version="true" />

<main class="page-container flex-center" id="conteudo-principal">
    <a href="#form-cadastro" class="sr-only-focusable">Pular para o formulário de cadastro</a>

    <div class="split-layout fade-in-element shadow-lg">
        
        <section class="form-column bg-gradient-dark" aria-labelledby="form-title">
            
            <a asp-controller="Home" asp-action="Index" class="btn-back text-moonstone" aria-label="Voltar para a página inicial">
                <svg aria-hidden="true" focusable="false" viewBox="0 0 24 24" width="20" height="20" fill="currentColor">
                    <path d="M20 11H7.83l5.59-5.59L12 4l-8 8 8 8 1.41-1.41L7.83 13H20v-2z"/>
                </svg>
                <span>Voltar</span>
            </a>

            <h2 id="form-title" class="sr-only">Formulário de Cadastro</h2>
            
            <form asp-action="SingIn" method="post" id="form-cadastro" class="cadastro-form">
                
                <div class="input-group">
                    <label for="email">Seu e-mail</label>
                    <input type="email" id="email" name="email" required aria-required="true" placeholder="exemplo@email.com" autocomplete="email" />
                    <span class="text-danger small error-message" aria-live="polite">O E-mail é obrigatorio.</span>
                </div>

                <div class="input-group">
                    <label for="numero">Seu telefone</label>
                    <input type="tel" id="numero" name="numero" required aria-required="true" placeholder="(00) 00000-0000" autocomplete="tel" />
                    <span class="text-danger small error-message" aria-live="polite">O telefone é obrigatorio.</span>
                </div>

                <div class="input-group">
                    <label for="senha">Escolha uma senha</label>
                    <input type="password" id="senha" name="senha" required aria-required="true" placeholder="••••••••" autocomplete="new-password" />
                    <span class="text-danger small error-message" aria-live="polite">A senha é obrigatorio.</span>
                </div>

                <button type="submit" class="btn-submit bg-gradient-moonstone" id="btn-submit">
                    <span class="btn-text">Cadastrar</span>
                </button>

                <div class="login-prompt">
                    <span class="text-champagne-muted">Já possui uma conta?</span>
                    <a asp-action="Login" class="link-moonstone" aria-label="Ir para a tela de login">
                        Faça Login
                    </a>
                </div>
            </form>
        </section>

        <section class="info-column bg-gradient-champagne">
            <div class="badge-label bg-moonstone-light">
                <span aria-hidden="true">👤</span> Crie sua Conta
            </div>
            
            <h1 class="main-heading">
                Junte-se a nós <br>
                <span class="text-moonstone">Hoje</span>
            </h1>
            
            <p class="description-text">
                Pronto para gerenciar seus dados com eficiência? Cadastre-se em nosso Sistema de Usuário e tenha acesso a um ambiente seguro, preciso e inovador desenhado para você.
            </p>

            <address class="contact-footer">
                <div class="contact-item">
                    <div class="icon-circle bg-gunmetal" aria-hidden="true">📞</div>
                    <span>+55 (11) 99999-9999</span>
                </div>
                <div class="contact-item">
                    <div class="icon-circle bg-gunmetal" aria-hidden="true">✉️</div>
                    <span>contato@sistema.com</span>
                </div>
            </address>
        </section>

    </div>
</main>

<script src="~/js/CadastroELogin.js" asp-append-version="true"></script>