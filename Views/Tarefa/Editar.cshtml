            const sections = document.querySelectorAll('.task-edit-container > div');
            sections.forEach((section, index) => {
                section.style.opacity = 0;
                section.style.transition = `opacity 0.6s ease ${index * 0.1}s`;
                setTimeout(() => section.style.opacity = 1, 10);
            });

            const inputs = document.querySelectorAll('.custom-input');
            inputs.forEach(input => {

                input.addEventListener('mouseover', () => {

                    input.style.boxShadow = '0 0 0 2px rgba(13, 110, 253, 0.1)';
                });
                input.addEventListener('mouseout', () => {
                    input.style.boxShadow = 'none';
                });

                input.addEventListener('focus', () => {

                });
            });

   
            const contactCards = document.querySelectorAll('.contact-card');
            contactCards.forEach(card => {
                const content = card.querySelector('.contact-card-content');
                const avatar = card.querySelector('.contact-avatar');


                card.addEventListener('click', () => {

                    if (card.querySelector('input').checked) {

