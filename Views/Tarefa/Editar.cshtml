@model ModuloMVC.ViewModels.TarefaEdicaoViewModel

<link rel="stylesheet" href="~/css/Tarefa.css" asp-append-version="true" />
<link rel="stylesheet" href="~/css/TarefaResp.css" asp-append-version="true" />

<div class="container my-5 task-edit-container">
    <div class="row gx-5">

        <div class="col-lg-5 mb-3 mb-md-0 current-data-section">

            <a href="@Url.Action("Index", "Tarefa")" class="back-link d-inline-block mb-3 text-decoration-none text-muted">
              <i class="bi bi-arrow-left-circle"></i>
            </a>

            <h2 class="mb-4">Detalhes da Tarefa</h2>

            <div class="data-group">
                <span class="data-label">Título:</span>
                <p class="data-value">@Model.TituloAtual</p>
            </div>

            <div class="data-group">
                <span class="data-label">Vencimento:</span>
                <p class="data-value">@(Model.VencimentoAtual?.ToString("dd/MM/yyyy") ?? "Sem data de vencimento")</p>
            </div>

            <div class="data-group">
                <span class="data-label">Descrição:</span>
                <p class="data-value">@Model.DescricaoAtual</p>
            </div>

            <div class="data-group">
                <span class="data-label">Status Atual:</span>
                <p class="data-value d-flex align-items-center gap-2">
                    <span class="status-dot @(Model.StatusAtual.ToString().ToLower())"></span>
                </p>
            </div>

            <div class="data-group mt-4">
                <span class="data-label">Contatos Atuais:</span>
                <ul class="list-unstyled">
                    @if (Model.ContatosEnvolvidosAtuais != null && Model.ContatosEnvolvidosAtuais.Any())
                    {
                        foreach (var contato in Model.ContatosEnvolvidosAtuais)
                        {
                            <li class="data-value text-muted">- @contato.Nome</li>
                        }
                    }
                    else
                    {
                        <li class="data-value text-muted">Nenhum contato atribuído.</li>
                    }
                </ul>
            </div>

            <div class="mt-5 pt-4 border-top">
                <button type="button"  class="btn btn-link text-danger p-0 text-decoration-none custom-delete-btn"
                        data-bs-toggle="modal" data-bs-target="#modalExcluirTarefa">
                    <i class="bi bi-trash3"></i> Excluir Tarefa
                </button>
            </div>
        </div>



        <div class="col-md-7">
            <form id="formEditTarefa" asp-action="Editar" method="post" novalidate>
                <input type="hidden" asp-for="Id" />

                <div class="row">
                    <div class="col-12 mb-3">
                        <label asp-for="Titulo" class="editar-form-label custom-label">Título</label>
                        <input type="text" asp-for="Titulo" class="form-control custom-input" required>
                        <span asp-validation-for="Titulo" class="text-danger small"></span>
                    </div>
                </div>

                <div class="row">
                    <div class="col-12 mb-3">
                        <label asp-for="Descricao" class="editar-form-label custom-label">Descrição</label>
                        <textarea asp-for="Descricao" class="form-control custom-input" rows="4" required></textarea>
                        <span asp-validation-for="Descricao" class="text-danger small"></span>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-4">
                        <label asp-for="Vencimento" class="editar-form-label custom-label">Vencimento</label>
                        <input type="date" asp-for="Vencimento" class="form-control custom-input" required>
                    </div>
                </div>

                <div class="status-section mb-4">
                    <label class="editar-form-label custom-label mb-3">Status da Tarefa</label>

                    <div class="status-options-container d-flex gap-2">
                        <label class="status-card flex-fill text-center">
                            <input type="radio" name="Status" value=1 class="status-radio" @((int)Model.Status == 1 ?
                                                                                                                                                                                                                                                    "checked" : "") required>
                            <div class="status-card-content py-2 px-3">Pendente</div>
                        </label>

                        <label class="status-card flex-fill text-center">
                            <input type="radio" name="Status" value=2 class="status-radio" @((int)Model.Status == 2 ?
                                                                                                                                                                                                                                                                       "checked" : "")>
                            <div class="status-card-content py-2 px-3">Em andamento</div>
                        </label>

                        <label class="status-card flex-fill text-center">
                            <input type="radio" name="Status" value=3 class="status-radio" @((int)Model.Status == 3 ?
                                                                                                                                                                                                                                                   "checked" : "")>
                            <div class="status-card-content py-2 px-3">Concluído</div>
                        </label>
                    </div>
                </div>

                <div class="contact-section mb-4">
                    <h5 class="mb-3 custom-label">Chamar para tarefa</h5>

                    <div class="contact-list-container">
                        @foreach (var contato in Model.TodosContatosDisponiveis)
                        {
                            bool isSelected = Model.ContatosSelecionadosIds != null &&
                        Model.ContatosSelecionadosIds.Contains(contato.Id);

                            <label class="contact-card d-block mb-2">
                                <input type="checkbox" name="ContatosSelecionadosIds" value="@contato.Id"
                                       class="editar-contact-checkbox" @(isSelected ? "checked" : "")>

                                <div class="contact-card-content d-inline-block ms-2">
                                    <span class="contact-name fw-bold">@contato.Nome</span>
                                    <span class="contact-email text-muted small ms-2">@contato.Email</span>
                                </div>
                            </label>
                        }
                    </div>
                </div>

                <button type="submit" class="btn btn-primary custom-submit-btn w-100 py-3" id="btnSubmit">
                    <span class="btn-text fw-bold">Salvar Alterações</span>
                </button>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="modalExcluirTarefa" tabindex="-1" aria-labelledby="modalExcluirTarefaLabel"
     aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="border-radius: 12px; border: none; box-shadow: 0 10px 30px rgba(0,0,0,0.1);">

            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold text-danger" id="modalExcluirTarefaLabel">Confirmar Exclusão</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fechar"></button>
            </div>

            <div class="modal-body text-secondary mt-2">
                Tem certeza que deseja excluir a tarefa <strong>"@Model.TituloAtual"</strong>? <br>
                Esta ação é permanente e não poderá ser desfeita.
            </div>

            <div class="modal-footer border-0 pt-1 pb-3">
                <button type="button" class="btn btn-light" data-bs-dismiss="modal"
                        style="border-radius: 8px; font-weight: 500;">Cancelar</button>

                <form action="/Tarefa/Excluir" method="post" class="m-0">
                    <input type="hidden" name="Id" value="@Model.Id" />
                    <button type="submit" class="btn btn-danger" style="border-radius: 8px; font-weight: 500;">Sim,
                        Excluir</button>
                    </form>
                </div>

            </div>
        </div>
    </div>

        @if (TempData["ExcluirTarefa"] != null && TempData["ExcluirTarefa"].ToString() != "1")
        {
        <div class="toast-container position-fixed top-0 end-0 p-3" style="z-index: 1055;">
            <div id="toastNotificacao" class="toast align-items-center text-white bg-danger border-0 shadow-lg" role="alert"
                 aria-live="assertive" aria-atomic="true" data-bs-delay="6000">
                <div class="d-flex">
                    <div class="toast-body fw-medium">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["ExcluirTarefa"]
                    </div>
                    <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"
                            aria-label="Fechar"></button>
                </div>
            </div>
        </div>
    }

           @if (TempData["CriarDublicado"] != null && TempData["CriarDublicado"].ToString() != "1")
    {
        <div class="toast-container position-fixed top-0 end-0 p-3" style="z-index: 1055;">
            <div id="toastNotificacao" class="toast align-items-center text-white bg-danger border-0 shadow-lg" role="alert"
                 aria-live="assertive" aria-atomic="true" data-bs-delay="6000">
                <div class="d-flex">
                    <div class="toast-body fw-medium">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["CriarDublicado"]
                    </div>
                    <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"
                            aria-label="Fechar"></button>
                </div>
            </div>
        </div>
    }

